{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EquipmentSchema",
  "description": "装备数据结构定义（M3 统一效果系统格式）",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "quality",
    "effects"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "weapon",
        "armor",
        "accessory"
      ]
    },
    "element": {
      "type": "string",
      "enum": [
        "metal",
        "wood",
        "water",
        "fire",
        "earth",
        "none"
      ]
    },
    "quality": {
      "type": "string",
      "enum": [
        "white",
        "green",
        "blue",
        "purple",
        "orange"
      ]
    },
    "cost": {
      "type": "integer",
      "minimum": 1
    },
    "shop_visible": {
      "type": "boolean",
      "default": true
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "op"
        ],
        "properties": {
          "op": {
            "type": "string"
          },
          "stat": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        }
      }
    },
    "trigger": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "chance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cooldown": {
          "type": "number",
          "minimum": 0
        },
        "mp_cost": {
          "type": "number",
          "minimum": 0
        },
        "effects": {
          "type": "array"
        }
      }
    },
    "recipe": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
