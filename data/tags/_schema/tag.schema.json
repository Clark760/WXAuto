{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TagSchema",
  "description": "标签定义结构（用于联动与检索）",
  "type": "object",
  "required": [
    "id",
    "name",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
